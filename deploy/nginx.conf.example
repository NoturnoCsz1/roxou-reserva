# /etc/nginx/sites-available/reserva.roxou.com.br
server {
    listen 80;
    server_name reserva.roxou.com.br;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name reserva.roxou.com.br;

    ssl_certificate     /etc/letsencrypt/live/reserva.roxou.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/reserva.roxou.com.br/privkey.pem;

    root /var/www/reserva-roxou/dist;
    index index.html;

    gzip on;
    gzip_types text/plain application/javascript application/json text/css image/svg+xml;

    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }
}